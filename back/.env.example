NODE_ENV=dev

DATABASE_URL = postgresql://<username>:<password>@localhost:5432/<database_name>

JWT_SECRET = abc

POSTGRESQL_USERNAME = database_user
POSTGRESQL_PASSWORD = database_password
POSTGRESQL_DATABASE = database_name


SENDGRID_API_KEY=algo 
EMAIL_FROM = algo

APP_URL=algo

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGIN=http://localhost:3000

# Datadog (opcional - para monitoramento APM)
DD_API_KEY=your-datadog-api-key
# IMPORTANTE: DD_SITE deve ser apenas o domínio, SEM https://
# Exemplos: us5.datadoghq.com, datadoghq.eu, datadoghq.com
DD_SITE=us5.datadoghq.com
